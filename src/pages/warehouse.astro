---
/**
 * Strona widoku magazynowego (/warehouse).
 *
 * Renderuje wyspe React WarehouseApp z client:load.
 * Uwierzytelnienie zarzadzane po stronie klienta przez AuthProvider.
 */
import Layout from "../layouts/Layout.astro";
import WarehouseApp from "../components/warehouse/WarehouseApp";
---

<Layout title="Widok Magazynowy — System Zlecen Transportowych">
  <style>
    @page { size: landscape; }
  </style>
  <div class="warehouse-view">
    <WarehouseApp client:load />
  </div>
</Layout>
