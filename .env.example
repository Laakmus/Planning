# Supabase (local development)
# Po uruchomieniu `supabase start` użyj kluczy z outputu komendy `supabase status`
SUPABASE_URL=http://127.0.0.1:54331
SUPABASE_ANON_KEY=<your-anon-key-from-supabase-start>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key-from-supabase-start>

# Public variables (dostępne w kodzie client-side)
PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
PUBLIC_SUPABASE_ANON_KEY=<your-anon-key-from-supabase-start>

# CORS — allowed origin for API requests (no wildcard in production!)
CORS_ORIGIN=http://localhost:4321

# Microsoft Graph API (opcjonalne — bez tych zmiennych email działa przez .eml fallback)
# Rejestracja: Azure Portal → App registrations → SPA, redirect URI = origin aplikacji
# Wymagane uprawnienia: Microsoft Graph → Mail.ReadWrite (delegated)
PUBLIC_MICROSOFT_CLIENT_ID=
PUBLIC_MICROSOFT_TENANT_ID=

# Sentry (opcjonalne — bez DSN error tracking wyłączony)
PUBLIC_SENTRY_DSN=
