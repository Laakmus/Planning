# ============================================================
# Planning App — konfiguracja produkcyjna
# ============================================================
# Skopiuj ten plik jako .env i uzupełnij wartości.
# NIGDY nie commituj pliku .env z prawdziwymi kluczami!

# Supabase (self-hosted lub cloud)
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Public variables (widoczne w przeglądarce — ustaw na domenę/IP serwera)
PUBLIC_SUPABASE_URL=https://your-domain.com/supabase
PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# CORS — domena produkcyjna (BEZ trailing slash!)
CORS_ORIGIN=https://your-domain.com

# Node.js
HOST=0.0.0.0
PORT=4321

# Microsoft Graph API (opcjonalne — bez tych zmiennych email działa przez .eml fallback)
# Po migracji na backend (P1-01): zamień PUBLIC_ na server-side zmienne
PUBLIC_MICROSOFT_CLIENT_ID=
PUBLIC_MICROSOFT_TENANT_ID=
# MICROSOFT_CLIENT_SECRET=<server-side-secret-after-P1-01>
