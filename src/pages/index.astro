---
/**
 * Strona logowania (/).
 *
 * Renderuje formularz LoginCard jako React island z client:load.
 * Zmienne Supabase przekazywane jako props (PUBLIC_*), żeby klient
 * mógł nawiązać sesję bezpośrednio z przeglądarki.
 */
import Layout from "../layouts/Layout.astro";
import LoginCard from "../components/auth/LoginCard";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<Layout title="Logowanie — System Zleceń Transportowych">
  <LoginCard
    client:load
    supabaseUrl={supabaseUrl}
    supabaseAnonKey={supabaseAnonKey}
  />
</Layout>
